# Only set the keys for the provider(s) you use.
# See config.yaml → llm section for which provider each role uses.

# OPENROUTER_API_KEY=sk-or-...
# GROQ_API_KEY=gsk_...
# NVIDIA_API_KEY=nvapi-...
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=AI...

# Web-server hardening (required when exposing the API beyond localhost)
# VERITY_API_TOKEN=replace-with-a-long-random-token
# VERITY_REQUIRE_API_TOKEN=true
# VERITY_HOST=127.0.0.1
# VERITY_PORT=8000
# VERITY_MAX_ACTIVE_RUNS=2

# Run open (no token) beyond localhost on a personal deployment. Only meaningful
# when VERITY_API_TOKEN is unset; abuse is then bounded by the rate limiter below.
# VERITY_ALLOW_UNAUTHENTICATED=true

# Per-IP rate limiting for /api/run (protects your provider credits and RAM).
# Set VERITY_RATE_LIMIT_RUNS=0 to disable.
# VERITY_RATE_LIMIT_RUNS=20
# VERITY_RATE_LIMIT_WINDOW_SECONDS=3600
